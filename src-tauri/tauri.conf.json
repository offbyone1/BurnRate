{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri.schema.json",
  "productName": "BurnRate",
  "version": "0.1.0",
  "identifier": "com.offbyone1.burnrate",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BurnRate",
        "width": 270,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
