{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BurnRate",
  "version": "0.1.0",
  "identifier": "com.offbyone1.burnrate",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BurnRate",
        "width": 270,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "plugins": {}
}
